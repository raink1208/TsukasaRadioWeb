[{"data":1,"prerenderedAt":167},["ShallowReactive",2],{"archive":3},[4,62,81,99],{"id":5,"title":6,"archiveId":7,"body":8,"date":52,"description":53,"draft":54,"extension":55,"meta":56,"navigation":54,"path":57,"seo":58,"stem":59,"videoId":60,"__hash__":61},"archive/archive/archive0004.md","第4回 深夜の大喜利大会を開催します。","archive0004",{"type":9,"value":10,"toc":41},"minimal",[11,15,19,22,25,28,33,37],[12,13,14],"h2",{"id":14},"深夜に領国民の大喜利を見てケタケタ笑う",[16,17,18],"p",{},"領国つかさの深夜放送、第4回目は深夜の大喜利大会！",[16,20,21],{},"今回の放送では、事前に領国民から募集した大喜利のお題に対する回答を見て楽しむ、参加型の企画が開催されました。\n驚くべきことに、250件もの応募が寄せられ、その中から領国つかさ本人が厳選した作品を紹介、閣下のユーモアセンスも試されるような内容でした。",[16,23,24],{},"深夜放送ならではの、まったりとした雰囲気の中で雑談も交えながら進行された大喜利大会は、笑いとチルさが調和した心地のいい放送となりました。",[12,26,27],{"id":27},"印章に残った回答のピックアップ",[29,30,32],"h3",{"id":31},"お題1-この深夜ラジオ絶対に何かおかしいその理由とは","お題1: この深夜ラジオ、絶対に何かおかしい...その理由とは？",[29,34,36],{"id":35},"お題2-カップラーメンの新商品謎すぎる味どんな味","お題2: カップラーメンの新商品「謎すぎる味」どんな味？",[29,38,40],{"id":39},"お題3-陰キャが陽キャに転生最初に何をする","お題3: 陰キャが陽キャに転生、最初に何をする？",{"title":42,"searchDepth":43,"depth":43,"links":44},"",2,[45,46],{"id":14,"depth":43,"text":14},{"id":27,"depth":43,"text":27,"children":47},[48,50,51],{"id":31,"depth":49,"text":32},3,{"id":35,"depth":49,"text":36},{"id":39,"depth":49,"text":40},"2025-03-10T00:00:00.000Z","領国民から募集したお悩みに真剣に回答していく放送。",true,"md",{},"/archive/archive0004",{"title":6,"description":53},"archive/archive0004","XB6-suIj9dQ","fsulK7FJHt",{"id":63,"title":64,"archiveId":65,"body":66,"date":73,"description":74,"draft":54,"extension":55,"meta":75,"navigation":54,"path":76,"seo":77,"stem":78,"videoId":79,"__hash__":80},"archive/archive/archive0003.md","第3回 ファミレス『ムーンパレス』へ行こう。","archive0003",{"type":9,"value":67,"toc":71},[68],[16,69,70],{},"archive3",{"title":42,"searchDepth":43,"depth":43,"links":72},[],"2025-03-01T00:00:00.000Z","領国つかさおすすめのゲーム ファミレスを享受せよのプレイ配信。",{},"/archive/archive0003",{"title":64,"description":74},"archive/archive0003","D2cFRAKiYSo","MQadV8fKVA",{"id":82,"title":83,"archiveId":84,"body":85,"date":92
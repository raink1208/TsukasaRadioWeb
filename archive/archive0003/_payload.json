[{"data":1,"prerenderedAt":94},["ShallowReactive",2],{"archive0003":3},{"id":4,"title":5,"archiveId":6,"body":7,"date":84,"description":85,"draft":86,"extension":87,"meta":88,"navigation":86,"path":89,"seo":90,"stem":91,"videoId":92,"__hash__":93},"archive/archive/archive0003.md","第3回 ファミレス『ムーンパレス』へ行こう。","archive0003",{"type":8,"value":9,"toc":72},"minimal",[10,14,17,20,25,28,32,37,40,56,59,62,66,69],[11,12,13],"p",{},"第三回目は初めてのゲーム配信回\nファミレスを教授せよ\nプレイ済みである",[11,15,16],{},"つかさちゃんが1年前にプレイして影響を受けた\nファミレスに行ったツイートが増えた原因でもある",[11,18,19],{},"ゲーム開始",[21,22,24],"h2",{"id":23},"つか通初めてのゲーム回ファミレスを享受せよ","■つか通初めてのゲーム回「ファミレスを享受せよ」",[11,26,27],{},"閣下が去年にプレイし影響を受けてファミレスに行ったというツイートが増えた原因でもあるらしい。",[21,29,31],{"id":30},"印象に残った所やシーンネタバレ注意","■印象に残った所やシーン(ネタバレ注意!)",[33,34,36],"h3",{"id":35},"ゲームの始まり-bgm","ゲームの始まり, BGM",[33,38,39],{"id":39},"個性的なキャラクター",[41,42,43,47,50,53],"ul",{},[44,45,46],"li",{},"王様",[44,48,49],{},"セロニカ",[44,51,52],{},"ガラスパン",[44,54,55],{},"ツェネズ\n何やら月におびえている?",[33,57,58],{"id":58},"間違い探し",[11,60,61],{},"奥の部屋に閉じこもっている人「ツェネズ」から貰った間違い探しの本\nサイゼリヤの間違い探しをよくプレイしているから得意と言う閣下",[33,63,65],{"id":64},"_16桁の総当たり","16桁の総当たり",[11,67,68],{},"王様から貰った16桁の暗証番号付きの箱\nどこにもヒントは無く総当たりを試すことになる",[11,70,71],{},"0~9の16桁なので10^16で1000兆通りであり 1回試すのに1秒かかるとした場合1000兆秒で約3000万年程かかる計算になる",{"title":73,"searchDepth":74,"depth":74,"links":75},"",2,[76,77],{"id":23,"depth":74,"text":24},{"id":30,"depth":74,"text":31,"children":78},[79,81,82,83],{"id":35,"depth":80,"text":36},3,{"id":39,"depth":80,"text":39},{"id":58,"depth":80,"text":58},{"id":64,"depth":80,"text":65},"2025-03-01T00:00:00.000Z","領国つかさおすすめのゲーム ファミレスを享受せよのプレイ配信。",true,"md",{},"/archive/archive0003",{"title":5,"description":85},"archive/archive0003","D2cFRAKiYSo","bGTHxupRGyKeElQUuruBvSoyUsFxOBG75QrSdtQMCiw",1744423029953]